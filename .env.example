# Vercel runtime env vars — copy values into the Vercel dashboard for
# the `nastaran-web` project (Settings → Environment Variables). Variable
# names are EXACT and case-sensitive — Vercel exposes them as
# `process.env.<NAME>`.
#
# DO NOT put real secret values into this file. This file is tracked in
# git. Use it as a template; set the real values only in the Vercel
# dashboard (or in a local `.env.local` which is gitignored if you need
# them for `vercel dev` style local testing).
#
# Setup walkthrough: docs/PIPELINE-HANDOFF.md § 2.

# ─── Required for the request/publish pipeline ─────────────────────────

# Fine-grained Personal Access Token scoped to ONE repo (this one).
# Required scopes: Contents: Read/Write AND Pull requests: Read/Write.
# Nothing else (no Workflows, no Actions, no org-level).
GITHUB_TOKEN=

# Slug of the repo this project uses for `requests/` and `req/*` branches.
# Format: owner/repo
GITHUB_REPO=vampyren/nastaran-web

# Password the owner types at /admin/login to access /admin and
# /onskemal-kogen. Any 8+ chars. Stored as plain env; compared with
# crypto.timingSafeEqual.
ADMIN_PASSWORD=

# HMAC key for the admin session cookie (`nastaran-admin`). 16+ chars.
# Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# ─── Optional ──────────────────────────────────────────────────────────

# UI flag for preview-mode niceties on Preview deployments. NEVER used
# for authorization — admin gating is cookie-based. Leave blank.
NEXT_PUBLIC_PREVIEW_MODE=

# ─── DO NOT SET ────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY is intentionally NOT used by this project. The
# request-pipeline operator runs in Mode A (interactive Claude Code
# session) and uses the local Claude CLI's subscription session.
# Setting this variable in any env (Vercel OR local shell) would
# OVERRIDE the subscription auth and break the operator. See
# docs/PIPELINE-HANDOFF.md.
